rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper Functions
    function isSignedIn() { return request.auth != null; }
    function isAdmin() { return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true; }
    function existing() { return resource.data; }
    function incoming() { return request.resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // User Model
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'username', 'isAdmin', 'createdAt']) &&
             data.keys().size() == 5 &&
             data.uid == request.auth.uid &&
             data.email is string && data.email.size() <= 128 &&
             data.username is string && data.username.size() <= 128 &&
             data.isAdmin is bool &&
             data.createdAt is string;
    }

    match /users/{userId} {
      // Users can read their own data, Admins can read all users
      allow get: if isSignedIn() && isValidId(userId) && (request.auth.uid == userId || isAdmin());
      allow list: if isAdmin();
      
      // Users can create/update their profile
      allow create: if isSignedIn() && isValidId(userId) && request.auth.uid == userId &&
                    isValidUser(incoming()) && incoming().isAdmin == false && incoming().createdAt == request.time.toIsoString();
      allow update: if isSignedIn() && isValidId(userId) && request.auth.uid == userId &&
                    isValidUser(incoming()) &&
                    incoming().uid == existing().uid && 
                    incoming().createdAt == existing().createdAt &&
                    incoming().isAdmin == existing().isAdmin; // Users cannot change their admin status
      allow delete: if isAdmin();
    }

    // Product Model
    function isValidReview(data) {
       return data.keys().hasAll(['id', 'userId', 'userName', 'rating', 'comment', 'createdAt']) &&
              data.id is string && data.userId is string && data.userName is string && data.rating is number && data.comment is string && data.createdAt is string;
    }
    
    function isValidProduct(data) {
       return data.keys().hasAll(['title', 'category', 'price', 'discount_price', 'description', 'image', 'brand', 'stock', 'rating', 'created_at']) &&
              data.title is string && data.title.size() <= 200 &&
              data.category is string && data.category.size() <= 100 &&
              data.price is number && data.price >= 0 &&
              data.discount_price is number && data.discount_price >= 0 &&
              data.description is string && data.description.size() <= 5000 &&
              data.image is string && data.image.size() <= 1000 &&
              data.brand is string && data.brand.size() <= 100 &&
              data.stock is number && data.stock >= 0 &&
              data.rating is number && data.rating >= 0 && data.rating <= 5 &&
              data.created_at is string &&
              (!('tax' in data) || (data.tax is number && data.tax >= 0));
    }

    match /products/{productId} {
      allow read: if true;
      allow create: if isAdmin() && isValidId(productId) && isValidProduct(incoming());
      allow update: if isAdmin() && isValidId(productId) && isValidProduct(incoming()) && incoming().created_at == existing().created_at;
      allow delete: if isAdmin() && isValidId(productId);
    }

    // Order Model
    function isValidOrder(data) {
      return data.keys().hasAll(['user_id', 'total_amount', 'order_status', 'created_at', 'items', 'customer_details']) &&
             data.user_id is string && data.user_id.size() <= 128 &&
             data.total_amount is number && data.total_amount >= 0 &&
             data.order_status is string && data.order_status.size() <= 50 &&
             data.created_at is string &&
             data.items is list && data.items.size() <= 100 &&
             data.customer_details is map;
    }

    match /orders/{orderId} {
      // Admins read all, users read their own
      allow get: if isSignedIn() && isValidId(orderId) && (isAdmin() || existing().user_id == request.auth.uid);
      allow list: if isSignedIn() && (isAdmin() || resource.data.user_id == request.auth.uid);
      
      // Users can create own orders
      allow create: if isSignedIn() && isValidId(orderId) && 
                    isValidOrder(incoming()) && 
                    incoming().user_id == request.auth.uid &&
                    incoming().order_status == 'PROCESSING';
      
      // Admin update
      allow update: if isAdmin() && isValidId(orderId) && isValidOrder(incoming()) && incoming().user_id == existing().user_id;

      // Admin delete
      allow delete: if isAdmin() && isValidId(orderId);
    }
  }
}
