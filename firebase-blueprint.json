{
  "entities": {
    "User": {
      "title": "User",
      "description": "A registered user in the application.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "username": { "type": "string" },
        "isAdmin": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "Product": {
      "title": "Product",
      "description": "An ecommerce product.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "category": { "type": "string" },
        "price": { "type": "number" },
        "discount_price": { "type": "number" },
        "description": { "type": "string" },
        "image": { "type": "string" },
        "brand": { "type": "string" },
        "stock": { "type": "number" },
        "tax": { "type": "number" },
        "rating": { "type": "number" },
        "reviews": {
          "type": "array",
          "items": { "$ref": "#/entities/Review" }
        },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "category", "price"]
    },
    "Order": {
      "title": "Order",
      "description": "A user's checkout order.",
      "type": "object",
      "properties": {
        "user_id": { "type": "string" },
        "total_amount": { "type": "number" },
        "order_status": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" },
        "items": { "type": "array" },
        "customer_details": { "type": "object" }
      },
      "required": ["user_id", "total_amount", "order_status"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles"
    },
    "products/{productId}": {
      "schema": { "$ref": "#/entities/Product" },
      "description": "Product catalog"
    },
    "orders/{orderId}": {
      "schema": { "$ref": "#/entities/Order" },
      "description": "Customer orders"
    }
  }
}
